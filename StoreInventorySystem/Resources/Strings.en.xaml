    <s:String x:Key="str_About_F3" xmlns:s="clr-namespace:System;assembly=mscorlib">✔  Search and filter by category</s:String>
    <s:String x:Key="str_About_F4" xmlns:s="clr-namespace:System;assembly=mscorlib">✔  Data persistence via JSON files</s:String>
    <s:String x:Key="str_About_F5" xmlns:s="clr-namespace:System;assembly=mscorlib">✔  Export to CSV</s:String>
    <s:String x:Key="str_About_F6" xmlns:s="clr-namespace:System;assembly=mscorlib">✔  Localization: Ukrainian and English</s:String>
    <s:String x:Key="str_About_F7" xmlns:s="clr-namespace:System;assembly=mscorlib">✔  Light and dark themes</s:String>

