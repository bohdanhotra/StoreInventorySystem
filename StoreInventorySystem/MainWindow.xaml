<Window x:Class="StoreInventorySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Облік товарів - Головна" Height="450" Width="800"
        MinWidth="400" MinHeight="300" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="180" Background="#ECEFF1">
            <TextBlock Text="Меню" FontSize="18" FontWeight="SemiBold" Margin="10,20,10,20" HorizontalAlignment="Center"/>
            <Button Content="📦 Інвентар" Click="NavInventory_Click" Margin="10,5" Height="40"/>
            <Button Content="➕ Додати товар" Click="NavAdd_Click" Margin="10,5" Height="40"/>
            <Button Content="⚙ Налаштування" Margin="10,5" Height="40"/>
        </StackPanel>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>