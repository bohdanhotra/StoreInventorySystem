<Page x:Class="StoreInventorySystem.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InventoryPage">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Список товарів у наявності" FontSize="20" FontWeight="Bold"/>
            <TextBox Width="200" DockPanel.Dock="Right" HorizontalAlignment="Right" 
                     Margin="10,0,0,0" x:Name="SearchBox" VerticalContentAlignment="Center"/>
            <TextBlock Text="Пошук:" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </DockPanel>

        <DataGrid Grid.Row="1" x:Name="InventoryGrid" AutoGenerateColumns="True" 
                  AlternatingRowBackground="#F5F5F5" CanUserAddRows="False" IsReadOnly="True"/>
    </Grid>
</Page>