<Page x:Class="StoreInventorySystem.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Список товарів">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource str_Inventory_Title}"
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- Панель: пошук + фільтр + CSV -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Поле пошуку з текстом-підказкою -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{DynamicResource str_Inventory_Search}"
                           Foreground="{DynamicResource SubTextBrush}"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Фільтр по категорії -->
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Margin="0,0,8,0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="">
                                            <Setter Property="Text" Value="{DynamicResource str_Inventory_AllCategories}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Grid.Column="2"
                    Content="{DynamicResource str_Inventory_ExportCsv}"
                    Command="{Binding ExportCsvCommand}"
                    Margin="0"/>
        </Grid>

        <!-- Таблиця товарів -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Products}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>

                <DataGridTemplateColumn Header="{DynamicResource str_Col_Photo}" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImagePath}" Height="40" Width="40"
                                   Stretch="UniformToFill" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="{DynamicResource str_Col_Name}"
                                    Binding="{Binding Name}" Width="*"/>

                <DataGridTextColumn Header="{DynamicResource str_Col_Category}"
                                    Binding="{Binding Category}" Width="130"/>

                <DataGridTextColumn Header="{DynamicResource str_Col_Price}"
                                    Binding="{Binding Price, StringFormat={}{0:N2}}" Width="110"/>

                <DataGridTextColumn Header="{DynamicResource str_Col_Qty}"
                                    Binding="{Binding Quantity}" Width="70"/>

                <DataGridTemplateColumn Header="{DynamicResource str_Actions}" Width="165">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <Button Content="{DynamicResource str_Edit}"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Padding="10,4" Margin="0,0,4,0" FontSize="12"/>
                                <Button Content="{DynamicResource str_Delete}"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>