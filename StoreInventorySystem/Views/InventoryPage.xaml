<Page x:Class="StoreInventorySystem.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InventoryPage">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список товарів у наявності" Style="{StaticResource HeaderTextStyle}" Grid.Row="0"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Products}" AutoGenerateColumns="False" 
          CanUserAddRows="False" IsReadOnly="True" Margin="5">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Фото" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImagePath}" Height="40" Width="40" Stretch="UniformToFill"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Ціна" Binding="{Binding Price}" Width="80"/>
                <DataGridTextColumn Header="К-сть" Binding="{Binding Quantity}" Width="70"/>

                <DataGridTemplateColumn Header="Дії" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Видалити" 
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                            CommandParameter="{Binding}"
                            Background="Red" Foreground="White" FontSize="10" Height="25"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>