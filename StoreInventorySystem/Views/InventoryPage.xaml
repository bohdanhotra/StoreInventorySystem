<Page x:Class="StoreInventorySystem.Views.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="InventoryPage">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Список товарів у наявності" Style="{StaticResource HeaderTextStyle}" Grid.Row="0"/>

        <DataGrid Grid.Row="1" x:Name="InventoryGrid" 
                  ItemsSource="{Binding Products}" 
                  AutoGenerateColumns="False" 
                  AlternatingRowBackground="{StaticResource SecondaryBrush}" 
                  CanUserAddRows="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Назва товару" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Ціна (грн)" Binding="{Binding Price}" Width="150"/>
                <DataGridTextColumn Header="Залишок (шт)" Binding="{Binding Quantity}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>