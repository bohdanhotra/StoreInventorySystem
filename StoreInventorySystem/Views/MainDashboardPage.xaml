<Page x:Class="StoreInventorySystem.Views.MainDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель керування">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>

                <!-- Верхня частина: аватар + роль -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,8">
                    <Border Background="#22FFFFFF" CornerRadius="40"
                            Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="👤" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="UserNameText" Text="Користувач"
                               Foreground="{DynamicResource SidebarTextBrush}"
                               HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock x:Name="UserRoleText" Text="Manager"
                               Foreground="#AAFFFFFF"
                               HorizontalAlignment="Center" FontSize="12" Margin="0,2,0,0"/>
                    <Separator Background="#33FFFFFF" Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Нижня частина: кнопка Logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">
                    <Separator Background="#33FFFFFF" Margin="0,0,0,8"/>
                    <Button Content="{DynamicResource str_Nav_Logout}"
                            Click="Logout_Click"
                            Style="{StaticResource SidebarButtonStyle}"
                            Foreground="#FFAAAA"/>
                </StackPanel>

                <!-- Середина: навігаційні кнопки -->
                <StackPanel Margin="8,0">
                    <Button Content="{DynamicResource str_Nav_Home}"
                            Click="NavHome_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="{DynamicResource str_Nav_Inventory}"
                            Click="NavInventory_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="{DynamicResource str_Nav_AddProduct}"
                            Click="NavAdd_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="{DynamicResource str_Nav_Settings}"
                            Click="NavSettings_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                    <Button Content="{DynamicResource str_Nav_About}"
                            Click="NavAbout_Click"
                            Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Контент -->
        <Frame x:Name="ContentFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource BackgroundBrush}"/>
    </Grid>
</Page>