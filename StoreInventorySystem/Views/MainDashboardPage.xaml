<Page x:Class="StoreInventorySystem.Views.MainDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель керування">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource PrimaryBrush}" Grid.Column="0">
            <StackPanel Margin="10">
                <Ellipse Width="80" Height="80" Fill="White" Margin="0,20,0,10"/>
                <TextBlock x:Name="UserRoleText" Text="Адміністратор" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>
                <Separator Margin="0,20" Background="#55FFFFFF"/>

                <Button Content="🏠 Головна" Click="NavHome_Click" />
                <Button Content="📦 Товари" Click="NavInventory_Click" />
                <Button Content="📊 Звіти" Click="NavReports_Click" />
                <Button Content="📊 Add" Click="NavAdd_Click" />

                <Button Content="Logout" Click="Logout_Click" VerticalAlignment="Bottom" Margin="0,100,0,0"/>
            </StackPanel>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>