<Page x:Class="StoreInventorySystem.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:StoreInventorySystem.ViewModels"
      Title="Реєстрація у системі">

    <Page.DataContext>
        <vm:RegisterViewModel/>
    </Page.DataContext>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Border Width="360" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="32"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="{DynamicResource str_Register_Title}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <Label Content="{DynamicResource str_Register_Username}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"/>

                <Label Content="{DynamicResource str_Register_Password}"/>
                <PasswordBox x:Name="RegisterPasswordBox" Height="38" Margin="0,4,0,4"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource ErrorBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,4" TextWrapping="Wrap"/>

                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="{DynamicResource SuccessBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" TextWrapping="Wrap"/>

                <Button Content="{DynamicResource str_Register_Button}"
                        Command="{Binding RegisterCommand}"
                        CommandParameter="{Binding ElementName=RegisterPasswordBox}"
                        Height="42" Margin="0,0,0,10"/>

                <Button Content="{DynamicResource str_Register_GoLogin}"
                        Command="{Binding GoToLoginCommand}"
                        Background="Transparent"
                        Foreground="{DynamicResource PrimaryBrush}"
                        BorderThickness="0"
                        Margin="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>