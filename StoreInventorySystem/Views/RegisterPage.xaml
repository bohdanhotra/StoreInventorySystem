<Page x:Class="StoreInventorySystem.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:StoreInventorySystem.ViewModels"
      Title="Реєстрація у системі">

    <Page.DataContext>
        <vm:RegisterViewModel/>
    </Page.DataContext>

    <Grid Background="#F3F4F6">
        <Border Width="350" Height="420" Background="White" CornerRadius="10" Padding="30"
                VerticalAlignment="Center" HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Реєстрація" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Label Content="Новий логін:"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="30"/>

                <Label Content="Пароль:"/>
                <PasswordBox x:Name="RegisterPasswordBox" Margin="0,0,0,15" Height="30"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,5" TextWrapping="Wrap"/>

                <TextBlock Text="{Binding SuccessMessage}" Foreground="Green" HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Button Content="Зареєструватися" Command="{Binding RegisterCommand}" CommandParameter="{Binding ElementName=RegisterPasswordBox}" Height="35" Margin="0,0,0,10"/>

                <Button Content="Повернутися до входу" Command="{Binding GoToLoginCommand}" Background="Transparent" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>