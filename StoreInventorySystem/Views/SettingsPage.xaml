<Page x:Class="StoreInventorySystem.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Налаштування">

    <ScrollViewer Background="{DynamicResource BackgroundBrush}">
        <StackPanel Margin="30" MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock Text="{DynamicResource str_Settings_Title}"
                       Style="{StaticResource HeaderTextStyle}"/>

            <!--мови -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource str_Settings_Language}"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

                    <RadioButton Content="🇺🇦  Українська"
                                 IsChecked="{Binding SelectedLanguage, Converter={StaticResource EqualityConverter}, ConverterParameter=uk}"
                                 GroupName="Language" Margin="0,4"/>
                    <RadioButton Content="🇬🇧  English"
                                 IsChecked="{Binding SelectedLanguage, Converter={StaticResource EqualityConverter}, ConverterParameter=en}"
                                 GroupName="Language" Margin="0,4"/>
                </StackPanel>
            </Border>

            <!-- тема -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource str_Settings_Theme}"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

                    <RadioButton Content="☀️  Світла тема"
                                 IsChecked="{Binding SelectedTheme, Converter={StaticResource EqualityConverter}, ConverterParameter=Light}"
                                 GroupName="Theme" Margin="0,4"/>
                    <RadioButton Content="🌙  Темна тема"
                                 IsChecked="{Binding SelectedTheme, Converter={StaticResource EqualityConverter}, ConverterParameter=Dark}"
                                 GroupName="Theme" Margin="0,4"/>
                </StackPanel>
            </Border>

            <Button Content="{DynamicResource str_Save}"
                    Command="{Binding SaveCommand}"
                    Height="45" Width="200"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,12"/>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SuccessBrush}"
                       FontWeight="SemiBold" FontSize="14"/>

        </StackPanel>
    </ScrollViewer>
</Page>
