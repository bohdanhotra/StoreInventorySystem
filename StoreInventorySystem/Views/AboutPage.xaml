<Page x:Class="StoreInventorySystem.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Про програму">

    <ScrollViewer Background="{DynamicResource BackgroundBrush}">
        <StackPanel Margin="30" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="{DynamicResource str_About_Title}"
                       Style="{StaticResource HeaderTextStyle}"/>

            <!-- Шапка з назвою та іконкою -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="28" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{DynamicResource SecondaryBrush}"
                            CornerRadius="16" Width="72" Height="72"
                            Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="🏪" FontSize="36"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource str_About_AppName}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource str_About_Version}"
                                   Style="{StaticResource SubHeaderTextStyle}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{DynamicResource str_About_StackValue}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="13" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Опис -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <TextBlock Text="{DynamicResource str_About_Description}"
                           TextWrapping="Wrap" LineHeight="22"
                           Foreground="{DynamicResource SubTextBrush}"/>
            </Border>

            <!-- Можливості -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{DynamicResource str_About_Features}"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,14"/>
                    <TextBlock Text="{DynamicResource str_About_F1}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F2}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F3}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F4}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F5}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F6}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource str_About_F7}" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
