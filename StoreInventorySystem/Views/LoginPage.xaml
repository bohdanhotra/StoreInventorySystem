<Page x:Class="StoreInventorySystem.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:StoreInventorySystem.ViewModels"
      Title="Вхід у систему">

    <Page.DataContext>
        <vm:LoginViewModel/>
    </Page.DataContext>

    <Grid Background="#F3F4F6">
        <Border Width="350" Height="400" Background="White" CornerRadius="10" Padding="30"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Авторизація" FontSize="26" FontWeight="Bold" Foreground="#005A9E" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Label Content="Логін:"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Height="30"/>

                <Label Content="Пароль:"/>
                <PasswordBox x:Name="UserPasswordBox" Margin="0,0,0,15" Height="30"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Button Content="Увійти" Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=UserPasswordBox}" Height="35" Margin="0,0,0,10"/>

                <Button Content="Реєстрація" Command="{Binding GoToRegisterCommand}" Background="Transparent" Foreground="#005A9E" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>