<Page x:Class="StoreInventorySystem.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Головна">

    <Grid Background="{DynamicResource BackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding WelcomeText}" Style="{StaticResource HeaderTextStyle}"/>
            <TextBlock Text="Ось короткий огляд склаку на сьогодні."
                       Style="{StaticResource SubHeaderTextStyle}"/>
        </StackPanel>

        <!-- Картки статистики -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">

            <!-- Всього товарів (позицій) -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="📦" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="{DynamicResource str_Home_TotalProducts}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Загальна кількість одиниць -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="🗄️" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalItems}" FontSize="36" FontWeight="Bold"
                               Foreground="#0EA5E9"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="{DynamicResource str_Home_TotalItems}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Загальна вартість -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="💰" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalValue, StringFormat={}{0:N0} грн}" FontSize="28" FontWeight="Bold"
                               Foreground="#16A34A"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="{DynamicResource str_Home_TotalValue}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Мало на складі -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="⚠️" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LowStockCount}" FontSize="36" FontWeight="Bold"
                               Foreground="#DC2626"
                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                    <TextBlock Text="{DynamicResource str_Home_LowStock}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- Нижня частина: підказка -->
        <Border Grid.Row="2" Style="{StaticResource StatCardStyle}"
                VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="ℹ️" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Перейдіть до розділу 'Товари' для перегляду та управління списком товарів на складі."
                           TextWrapping="Wrap" VerticalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
