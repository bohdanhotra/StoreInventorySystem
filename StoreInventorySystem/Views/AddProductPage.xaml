<Page x:Class="StoreInventorySystem.Views.AddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StoreInventorySystem.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddProductPage">

    <StackPanel Margin="30" MaxWidth="500">
        <TextBlock Text="Новий товар" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Label Content="Назва:"/>
        <TextBox Text="{Binding NewProduct.Name}"/>

        <Label Content="Категорія:"/>
        <ComboBox x:Name="CategoryCombo">
            <ComboBoxItem Content="Електроніка"/>
            <ComboBoxItem Content="Одяг"/>
            <ComboBoxItem Content="Продукти"/>
        </ComboBox>

        <Label Content="Зображення:"/>
        <Button Content="Вибрати файл" Command="{Binding SelectImageCommand}"/>
        <Image Source="{Binding NewProduct.ImagePath}" Height="150" Margin="0,10"/>

        <Button Content="ЗБЕРЕГТИ" Command="{Binding SaveCommand}" Height="45" Margin="0,20"/>
    </StackPanel>
</Page>
