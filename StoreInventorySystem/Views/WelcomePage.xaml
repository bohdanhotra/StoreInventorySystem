<Page x:Class="StoreInventorySystem.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вітаємо">

    <Grid Background="#F3F4F6">
        <Border Width="400" Height="350" Background="White" CornerRadius="15" Padding="40" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Store Inventory" FontSize="32" FontWeight="Bold" Foreground="#005A9E" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Система керування складом" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Content="Увійти" Click="Login_Click" Height="45" Margin="0,0,0,10"/>
                <Button Content="Створити аккаунт" Click="Register_Click" Height="45" Background="#E6F2FA" Foreground="#005A9E" Margin="0,0,0,10"/>
                <Button Content="Вийти" Click="Exit_Click" Height="45" Background="Transparent" Foreground="Red" BorderBrush="Red" BorderThickness="1"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>