<Page x:Class="StoreInventorySystem.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вітаємо">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Border Width="420" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="14" Padding="40"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="{DynamicResource str_Welcome_Title}"
                           FontSize="34" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="{DynamicResource str_Welcome_Subtitle}"
                           FontSize="14"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <Button Content="{DynamicResource str_Welcome_Login}"
                        Click="Login_Click" Height="44" Margin="0,0,0,10"/>

                <Button Content="{DynamicResource str_Welcome_Register}"
                        Click="Register_Click" Height="44"
                        Background="{DynamicResource SecondaryBrush}"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Margin="0,0,0,10"/>

                <Button Content="{DynamicResource str_Welcome_Exit}"
                        Click="Exit_Click" Height="44"
                        Background="Transparent"
                        Foreground="{DynamicResource ErrorBrush}"
                        Margin="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>